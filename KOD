#include <iostream>

using namespace std;
void insertionSort(int arr[], int size) {
    for (int i = 1; i < size; i++) {
        int key = arr[i];
        int j = i - 1;
        while (j >= 0 && arr[j] < key) {
            arr[j + 1] = arr[j];
            j = j - 1;
        }
        arr[j + 1] = key;
    }
}
int main() {
    int n;
    cout << "Vvedit cile chislo n: ";
    cin >> n;
    if (n < 0) n = abs(n);
    if (n <= 1) return 0;
    int factors[64];
    int count = 0;
    int temp = n;
    for (int i = 2; i * i <= temp; i++) {
        if (temp % i == 0) {
            factors[count++] = i;
            while (temp % i == 0) {
                temp /= i;
            }
        }
    }
    if (temp > 1) {
        factors[count++] = temp;
    }
    cout << "Masiv prostih dilnikiv: ";
    for (int i = 0; i < count; i++) {
        cout << factors[i] << " ";
    }
    cout << endl;
    insertionSort(factors, count);
    cout << "Vidsortovaniy za ubuvannyam: ";
    for (int i = 0; i < count; i++) {
        cout << factors[i] << " ";
    }
    cout << endl;
    return 0;
}
