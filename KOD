#include <iostream>

using namespace std;
void insertionSort(int arr[], int size) {
    for (int i = 1; i < size; i++) {
        int key = arr[i];
        int j = i - 1;
        while (j >= 0 && arr[j] < key) {
            arr[j + 1] = arr[j];
            j = j - 1;
        }
        arr[j + 1] = key;
    }
}
int main() {
    int n;
    cout << "Vvedit cile chislo n: ";
    if (!(cin >> n)) return 1;
    if (n < 0) n = abs(n);
    if (n == 0 || n == 1) {
        cout << "Chislo ne mae prostih dilnikiv." << endl;
        return 0;
    }
    int tempFactors[32];
    int count = 0;
    int tempN = n;
    for (int i = 2; i * i <= tempN; i++) {
        if (tempN % i == 0) {
            tempFactors[count++] = i;
            while (tempN % i == 0) {
                tempN /= i;
            }
        }
    }
    if (tempN > 1) {
        tempFactors[count++] = tempN;
    }
    int* primeFactors = new int[count];
    for (int i = 0; i < count; i++) {
        primeFactors[i] = tempFactors[i];
    }
    cout << "Masiv prostih dilnikiv: ";
    for (int i = 0; i < count; i++) {
        cout << primeFactors[i] << " ";
    }
    cout << endl;
    insertionSort(primeFactors, count);
    cout << "Vidsortovaniy za ubuvannyam: ";
    for (int i = 0; i < count; i++) {
        cout << primeFactors[i] << " ";
    }
    cout << endl;
    delete[] primeFactors;
    return 0;
}
